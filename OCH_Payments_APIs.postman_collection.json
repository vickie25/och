    {
      "name": "04 - Webhooks (Manual/Forwarded)",
      "item": [
        {
          "name": "Subscription Stripe Webhook (Raw)",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Webhook endpoint responds', function(){",
                "  pm.expect(pm.response.code).to.be.oneOf([200,400,401]);",
                "});"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
