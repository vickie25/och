  "item": [
    {
      "name": "00 - Auth Setup",
      "item": [
        {
          "name": "Login (Get Token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "pm.test('Access token exists', function () {",
                  "  pm.expect(json.access || json.token).to.exist;",
                  "});",
                  "pm.collectionVariables.set('auth_token', json.access || json.token || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login", ""]
            }
          }
        }
      ]
    },
    {
      "name": "01 - Subscription Payments",
      "item": [
        {
          "name": "Get Paystack Config",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Response is object', function(){ pm.expect(json).to.be.an('object'); });"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/subscription/paystack/config/?plan={{plan}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subscription", "paystack", "config", ""],
              "query": [{ "key": "plan", "value": "{{plan}}" }]
            }
          }
        },
        {
          "name": "Initialize Paystack Subscription Payment",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is success', function(){ pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "const reference = json.reference || json.data?.reference || '';",
                "const authUrl = json.authorization_url || json.data?.authorization_url || '';",
                "pm.test('Reference exists', function(){ pm.expect(reference).to.be.a('string').and.not.empty; });",
                "pm.test('Authorization URL exists', function(){ pm.expect(authUrl).to.be.a('string').and.not.empty; });",
                "pm.collectionVariables.set('subscription_reference', reference);"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plan\": \"{{plan}}\",\n  \"gateway\": \"{{gateway}}\",\n  \"callback_url\": \"http://localhost:3000/payment/success\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscription/paystack/initialize/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subscription", "paystack", "initialize", ""]
            }
          }
        },
        {
          "name": "Verify Subscription Payment",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Has payment state', function(){",
                "  pm.expect(JSON.stringify(json)).to.match(/status|paid|success|verified/i);",
                "});"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reference\": \"{{subscription_reference}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/subscription/paystack/verify/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subscription", "paystack", "verify", ""]
            }
          }
        },
        {
          "name": "Billing History",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Response has array/object payload', function(){",
                "  const isArray = Array.isArray(json);",
                "  const hasList = Array.isArray(json.results) || Array.isArray(json.transactions) || Array.isArray(json.history);",
                "  pm.expect(isArray || hasList || typeof json === 'object').to.eql(true);",
                "});"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/subscription/billing-history/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "subscription", "billing-history", ""]
            }
          }
        }
      ]
    },
    {
      "name": "02 - Cohort Payments",
      "item": [
        {
          "name": "Initiate Cohort Payment",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is success', function(){ pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "const reference = json.reference || '';",
                "const paymentId = json.payment_id || '';",
                "if (reference) pm.collectionVariables.set('cohort_reference', reference);",
                "if (paymentId) pm.collectionVariables.set('cohort_payment_id', paymentId);",
                "pm.test('Reference captured when enrollment is valid', function(){",
                "  if (pm.collectionVariables.get('cohort_enrollment_id')) pm.expect(reference).to.be.a('string').and.not.empty;",
                "  else pm.expect(true).to.eql(true);",
                "});"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"enrollment_id\": \"{{cohort_enrollment_id}}\",\n  \"callback_url\": \"http://localhost:3000/cohorts/payment/return\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/cohorts/payment/initiate/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cohorts", "payment", "initiate", ""]
            }
          }
        },
        {
          "name": "Verify Cohort Payment",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Has payment status', function(){ pm.expect(json.status || json.payment_status).to.exist; });"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/cohorts/payment/verify/?reference={{cohort_reference}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cohorts", "payment", "verify", ""],
              "query": [{ "key": "reference", "value": "{{cohort_reference}}" }]
            }
          }
        },
        {
          "name": "Get Cohort Payment Status",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/cohorts/payment/status/?reference={{cohort_reference}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "cohorts", "payment", "status", ""],
              "query": [{ "key": "reference", "value": "{{cohort_reference}}" }]
            }
          }
        }
      ]
    },
