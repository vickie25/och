            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/checkout/sessions/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "checkout", "sessions", ""]
            }
          }
        },
        {
          "name": "List Sponsor Invoices",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "if (Array.isArray(json.results) && json.results.length) {",
                "  pm.collectionVariables.set('invoice_id', json.results[0].id || '');",
                "}"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/billing/invoices/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "invoices", ""]
            }
          }
        },
        {
          "name": "Create Org Enrollment Invoice (POST)",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is success', function(){ pm.expect(pm.response.code).to.be.oneOf([200,201]); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "if (json.id) pm.collectionVariables.set('invoice_id', json.id);",
                "if (json.paystack_reference) pm.collectionVariables.set('invoice_reference', json.paystack_reference);",
                "pm.test('Invoice id captured', function(){ pm.expect(pm.collectionVariables.get('invoice_id')).to.be.a('string').and.not.empty; });"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_id\": \"{{organization_id}}\",\n  \"contact_person_name\": \"Finance Manager\",\n  \"contact_email\": \"finance@example.com\",\n  \"contact_phone\": \"+254700000000\",\n  \"total_amount_kes\": 15000,\n  \"line_items\": [\n    {\n      \"student_name\": \"Student A\",\n      \"plan_name\": \"Starter\",\n      \"amount_kes\": 5000\n    },\n    {\n      \"student_name\": \"Student B\",\n      \"plan_name\": \"Starter\",\n      \"amount_kes\": 5000\n    },\n    {\n      \"student_name\": \"Student C\",\n      \"plan_name\": \"Starter\",\n      \"amount_kes\": 5000\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/org-enrollment-invoices/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "org-enrollment-invoices", ""]
            }
          }
        },
        {
          "name": "Get Org Enrollment Invoice (Public GET)",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Invoice payload returned', function(){ pm.expect(json.id || json.invoice_number).to.exist; });",
                "if (json.paystack_reference) pm.collectionVariables.set('invoice_reference', json.paystack_reference);"
              ]}
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/v1/billing/org-enrollment-invoices/{{invoice_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "org-enrollment-invoices", "{{invoice_id}}", ""]
            }
          }
        },
        {
          "name": "Verify Org Enrollment Invoice Payment (Public POST)",
          "auth": { "type": "noauth" },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is acceptable', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400]); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Response has status or error', function(){ pm.expect(json.status || json.error).to.exist; });"
              ]}
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"reference\": \"{{invoice_reference}}\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/org-enrollment-invoices/{{invoice_id}}/verify-payment/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "org-enrollment-invoices", "{{invoice_id}}", "verify-payment", ""]
            }
          }
        },
        {
          "name": "Update Org Enrollment Invoice Status (PATCH)",
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": [
                "pm.test('Status is 200', function(){ pm.response.to.have.status(200); });",
                "let json = {}; try { json = pm.response.json(); } catch(e) {}",
                "pm.test('Status changed', function(){ pm.expect(json.status).to.exist; });"
              ]}
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"waived\"\n}" },
            "url": {
              "raw": "{{base_url}}/api/v1/billing/org-enrollment-invoices/{{invoice_id}}/status/",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "billing", "org-enrollment-invoices", "{{invoice_id}}", "status", ""]
