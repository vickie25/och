# Copy to /var/www/och/.env on the server (same directory as docker-compose.yml).
# Used by docker-compose for Next.js *build args* (GOOGLE client IDs only).
# Do NOT commit real values.

# When the repo is under /var/www/och, the directory name is not "ongozacyberhub"; set this so
# `docker compose` reuses the same project, networks, and named volumes as before.
COMPOSE_PROJECT_NAME=ongozacyberhub

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Django also reads secrets from backend/django_app/.env (see below).
