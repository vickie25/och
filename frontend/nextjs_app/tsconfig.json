{
  "compilerOptions": {
    "target": "es2015",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "types": [],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/components/ui/button": [
        "./components/ui/Button"
      ],
      "@/components/ui/input": [
        "./components/ui/Input"
      ],
      "@/components/ui/label": [
        "./components/ui/Label"
      ],
      "@/components/ui/card": [
        "./components/ui/Card"
      ],
      "@/components/ui/select": [
        "./components/ui/Select"
      ],
      "@/components/ui/badge": [
        "./components/ui/Badge"
      ],
      "@/components/ui/dropdown-menu": [
        "./components/ui/dropdown-menu"
      ],
      "@/components/ui/progress": [
        "./components/ui/Progress"
      ],
      "@/components/ui/tabs": [
        "./components/ui/tabs"
      ],
      "@/components/ui/textarea": [
        "./components/ui/Textarea"
      ],
      "@/components/ui/switch": [
        "./components/ui/Switch"
      ],
      "@/components/ui/dialog": [
        "./components/ui/dialog"
      ],
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "supabase/functions",
    "**/*.disabled/**",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
