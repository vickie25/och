DEBUG=True
DJANGO_SETTINGS_MODULE=core.settings.development

# Core security
DJANGO_SECRET_KEY=django-insecure-local-dev-change-this
JWT_SECRET_KEY=jwt-local-dev-change-this
JWT_ALGORITHM=HS256

# Frontend/backend URLs (local)
FRONTEND_URL=http://localhost:3000
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,host.docker.internal,testserver
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOW_TUNNEL_HOSTS=true

# PostgreSQL
DB_NAME=ongozacyberhub
DB_USER=postgres
DB_PASSWORD=vick3900
DB_HOST=localhost
DB_PORT=5432
USE_SQLITE=false

# Redis / Celery (safe local defaults)
#REDIS_HOST=localhost
#REDIS_PORT=6379
#REDIS_PASSWORD=
#USE_REDIS_CACHE=false
#CELERY_BROKER_URL=redis://localhost:6379/0
#CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Metrics / monitoring
#ENABLE_METRICS=False
#SENTRY_DSN=

# OAuth (optional for startup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Payments (optional until payment endpoints/webhooks are tested)
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email (left blank; development falls back to console backend)
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=Ongoza CyberHub

# MFA / SMS / AI (optional)
MFA_TOTP_ENCRYPTION_KEY=local-mfa-encryption-key
MFA_EXEMPT_EMAILS=
SMS_PROVIDER=textsms
TEXTSMS_PARTNER_ID=
TEXTSMS_API_KEY=
TEXTSMS_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
CHAT_GPT_API_KEY=
OPENAI_API_KEY=
AI_COACH_MODEL=gpt-4o-mini

# Business/reporting defaults
VALUE_PER_CERTIFIED_STUDENT_KES=50000
ENGAGEMENT_WEIGHT_ACTIVITY=0.4
ENGAGEMENT_WEIGHT_PROGRESS=0.4
ENGAGEMENT_WEIGHT_LOGIN=0.2
LOGIN_FREQUENCY_TARGET_30D=8
EMPLOYER_PRICING_USD_TO_KES=160.0
